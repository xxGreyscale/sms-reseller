# SMS Reseller — local development environment template
# Copy to .env before starting the stack: cp .env.example .env
# .env is gitignored; this file is committed as documentation only.
#
# NOTE: Per-service SERVER_PORT and SPRING_DATASOURCE_URL are set inside the
# start script loop (scripts/start.sh) using a port-map and URL template, so
# they are NOT enumerated here — one template drives all 8 services cleanly.
# See scripts/start.sh for the port assignment: identity=8081 ... admin=8088.

# ---------------------------------------------------------------------------
# Postgres (consumed by both compose and services via Spring relaxed binding)
# ---------------------------------------------------------------------------
POSTGRES_USER=smsreseller
POSTGRES_PASSWORD=smsreseller
POSTGRES_DB=smsreseller

SPRING_DATASOURCE_USERNAME=smsreseller
SPRING_DATASOURCE_PASSWORD=smsreseller

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Azampay sandbox (placeholder values — never commit real credentials)
# Replace with real sandbox credentials from the Azampay developer portal.
# ---------------------------------------------------------------------------
AZAMPAY_BASE_URL=https://sandbox.azampay.co.tz
AZAMPAY_APP_NAME=sms-reseller
AZAMPAY_CLIENT_ID=placeholder
AZAMPAY_CLIENT_SECRET=placeholder
